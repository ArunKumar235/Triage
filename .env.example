DATABASE_URL=postgresql+asyncpg://{username}:{password}@localhost:5432/triage
WEBHOOK_SHARED_SECRET=secret

KAFKA_BOOTSTRAP_SERVERS=localhost:9092

KAFKA_TOPIC_TESTABLE_READY_FOR_TESTING=TESTABLE_READY_FOR_TESTING
KAFKA_TOPIC_MEMBER_AVAILABILITY_CHANGED=MEMBER_AVAILABILITY_CHANGED
KAFKA_TOPIC_ASSIGNMENT_COMPLETED=ASSIGNMENT_COMPLETED

KAFKA_TOPIC_TESTABLE_READY_FOR_TESTING_DLQ=TESTABLE_READY_FOR_TESTING_DLQ
KAFKA_TOPIC_MEMBER_AVAILABILITY_CHANGED_DLQ=MEMBER_AVAILABILITY_CHANGED_DLQ
KAFKA_TOPIC_ASSIGNMENT_COMPLETED_DLQ=ASSIGNMENT_COMPLETED_DLQ

ORCHESTRATOR_MODEL=gpt-oss:120b-cloud

VECTOR_STORE_PATH=./vector_store
EMBEDDING_MODEL=nomic-embed-text:v1.5

LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=<your_langsmith_api_key>
LANGCHAIN_PROJECT=Triage

SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_STARTTLS=false
NOTIFICATION_FROM_EMAIL=no-reply@triage.com